{
  "name": "@poker/server",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "dev": "tsx watch --ignore ../shared/dist --ignore ../shared/src src/index.ts",
    "start": "node dist/index.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "db:migrate": "prisma migrate dev",
    "db:seed": "tsx prisma/seed.ts"
  },
  "dependencies": {
    "@fastify/cookie": "^11",
    "@fastify/cors": "^11",
    "@fastify/rate-limit": "^10",
    "@poker/shared": "workspace:*",
    "@prisma/client": "^6",
    "dotenv": "^17.4.0",
    "fastify": "^5",
    "jsonwebtoken": "^9",
    "socket.io": "^4",
    "uuid": "^11"
  },
  "devDependencies": {
    "@types/jsonwebtoken": "^9",
    "@types/uuid": "^10",
    "prisma": "^6",
    "socket.io-client": "^4",
    "tsx": "^4",
    "typescript": "^5.7",
    "vitest": "^3"
  }
}
