{
  "name": "@poker/terminal",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "bin": {
    "poker": "./dist/cli/index.js"
  },
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "dev": "tsx watch src/cli/index.tsx",
    "watch:build": "tsc -p tsconfig.build.json --watch",
    "start": "tsx src/cli/index.tsx",
    "test": "vitest run",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@poker/shared": "workspace:*",
    "ink": "^6.8.0",
    "react": "^19",
    "react-devtools-core": "^6",
    "socket.io-client": "^4"
  },
  "devDependencies": {
    "@fastify/cookie": "^11",
    "@fastify/cors": "^11",
    "@poker/server": "workspace:^",
    "@types/node": "^25.5.0",
    "@types/react": "^19",
    "execa": "^9.6.1",
    "fastify": "^5",
    "socket.io": "^4",
    "socket.io-client": "^4.8.3",
    "tsx": "^4",
    "typescript": "^5.7",
    "vitest": "^3"
  }
}
